<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Profile Page</title>
<link rel="stylesheet" href="profcss.css">
</head>
<body>

<div class="container">

    <h2>My Profile</h2>

    <!-- PROFILE PIC -->
    <div class="profile-wrapper" onclick="openFile()">
        <img id="profilePic" src="https://via.placeholder.com/120" class="profile-img">
        <div class="camera-icon">📷</div>
    </div>
    <input type="file" id="imageUpload" accept="image/*">

    <!-- INFO -->
    <div class="info">
        <p><b>Username:</b> <span id="username"></span></p>
        <p><b>Email:</b> <span id="email"></span></p>
        <p><b>Phone:</b> <span id="phone"></span></p>
        <p><b>Bio:</b> <span id="bio"></span></p>
    </div>

    <select onchange="changeTheme(this.value)">
    <option value="">Choose Theme</option>
    <option value="light">Light Mode</option>
    <option value="dark">Dark Mode</option>
</select>

    <!-- EDIT BUTTON -->
    <button onclick="openModal()">Edit Profile</button>

</div>

<!-- MODAL -->
<div class="modal" id="editModal">
    <div class="modal-content">

        <h3>Edit Profile</h3>

        <div class="input-group">
            <input type="text" id="newUsername" placeholder="Username">
        </div>

        <div class="input-group">
            <input type="email" id="newEmail" placeholder="Email">
        </div>

        <div class="input-group">
            <input type="password" id="newPassword" placeholder="Password">
        </div>

        <div class="input-group">
            <input type="text" id="newPhone" placeholder="Phone">
        </div>

        <div class="input-group">
            <textarea id="newBio" placeholder="Bio"></textarea>
        </div>

        <button onclick="updateProfile()">Save Changes</button>
        <button onclick="closeModal()">Cancel</button>

    </div>
</div>

<script src="profjs.js"></script>

</body>
</html>
